# ══════════════════════════════════════════════════════════════════════════════
#  Libratus — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores antes de rodar o projeto.
#  NUNCA versione o arquivo .env — ele já está no .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────────────────────
# Chave secreta para sessões e CSRF. Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-segura

# ── Banco de dados ─────────────────────────────────────────────────────────
# Diretório onde o arquivo libratus.db será criado.
# Em produção, use um caminho absoluto fora do repositório.
DATA_DIR=data

# ── Ambiente ───────────────────────────────────────────────────────────────
# "development" habilita o debug mode. Use "production" em deploy.
FLASK_ENV=development
